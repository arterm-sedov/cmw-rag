# Copy to .env in this folder (.env is gitignored).
# Used by docs/deployment/pdf/build.ps1.

# cbap-mkdocs-ru checkout with mkdocs_common.yml, pdf_templates/, and .venv.
# Auto-discovery prefers sibling ../cbap-mkdocs-ru, then .reference-repos/cbap-mkdocs-ru.
# CBAP_MKDOCS_ROOT=../../../../cbap-mkdocs-ru

# GTK3 bin for WeasyPrint on Windows (cbap-mkdocs-ru install/installgtk3.ps1).
# GTK3_BIN=C:\Program Files\GTK3-Runtime Win64\bin

# Cover footer only: build.ps1 sets MKDOCS_PDF_FOOTER_LEFT = "<author> <date>" (see mkdocs.yml extra.pdf.frontpage).
# PDF_AUTHOR=Составил Артём Седов
# PDF_DATE=2026-06-25
